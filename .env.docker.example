MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=ai-book-reader
MONGO_URI=mongodb://mongodb:27017/ai-book-reader

PYTHON_BACKEND_HOST=python-backend
PYTHON_BACKEND_PORT=8000
PYTHON_BACKEND_URL=http://python-backend:8000

BACKEND_HOST=backend
BACKEND_PORT=5000
NODE_ENV=development
UPLOADS_PATH=/app/uploads

SESSION_SECRET=docker-dev-session-secret
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
MOBILE_AUTH_SUCCESS_URL=aibookreader://auth-success
